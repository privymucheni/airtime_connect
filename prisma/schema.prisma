generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Connection pooling configuration
  directUrl = env("DATABASE_URL_DIRECT")
}

enum UserRole {
  ADMIN
  COMPANY
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  COMPLETED
  FAILED
  PROCESSING
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  password      String
  role          UserRole        @default(COMPANY)
  companyName   String?
  status        UserStatus      @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  wallet        Wallet?
  transactions  Transaction[]
  systemLogs    SystemLog[]
  subscriptions Subscription[]
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  amount          Float
  type            TransactionType
  status          TransactionStatus @default(COMPLETED)
  recipientsCount Int               @default(0)
  recipients      Recipient[]
  paymentMethod   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Recipient {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  name          String
  phoneNumber   String
  amount        Float
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
}

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Float
  expiryDate      DateTime
  isActive        Boolean  @default(true)
  maxUsages       Int      @default(100)
  currentUsages   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  subscriptions   Subscription[]
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  planName    String   // e.g., "Silver", "Gold", "Platinum"
  amount      Float
  status      String   @default("active")
  promoCodeId String?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id])
  startDate   DateTime @default(now())
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ChatBotQuestion {
  id            String            @id @default(cuid())
  question      String
  answer        String?           @db.Text
  parentId      String?
  parent        ChatBotQuestion?  @relation("SubQuestions", fields: [parentId], references: [id], onDelete: Cascade)
  subQuestions  ChatBotQuestion[] @relation("SubQuestions")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}
